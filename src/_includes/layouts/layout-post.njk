<!DOCTYPE html>
<html lang="es">
  <head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{{ title }}</title>
    <meta name="description" content="{{ description }}">
    <link href="https://cdn.jsdelivr.net/npm/bulma@0.9.4/css/bulma.min.css" rel="stylesheet">
    <link rel="stylesheet" href="{{ '/css/styles.css' | url }}">

    <!-- Google tag (gtag.js) -->
    <script async src="https://www.googletagmanager.com/gtag/js?id=G-C4J1GFZMPF"></script>
    <script>
      window.dataLayer = window.dataLayer || [];
      function gtag() {
        dataLayer.push(arguments);
      }
      gtag('js', new Date());
      gtag('config', 'G-C4J1GFZMPF');
    </script>
  </head>

  <body>
    <div class="container">
      {% include "header.njk" %}

      <div class="layout">
        <div class="columns is-variable is-6 is-multiline">

          <!-- Sidebar -->
          <div class="column is-12-tablet is-3-desktop">
            {% include "nav_posts.njk" %}
          </div>

          <!-- Contenido centrado -->
          <div class="column is-12-tablet is-6-desktop">
            <main class="content is-medium">
              <h1 class="title is-3">{{ title }}</h1>
              <p class="has-text-grey">
  Publicado: {{ date | date }}
                {% set modified = page.inputPath | lastModified %}
                {% if modified and modified != (date | date) %}
    &nbsp;·&nbsp; Actualizado: {{ modified }}
                {% endif %}
              </p>
              <hr>

              {{ content | safe }}
            </main>
          </div>

          <!-- Espacio para balancear -->
          <div class="column is-hidden-touch is-3-desktop"></div>

        </div>
      </div>

      {% include "footer.njk" %}
    </div>

    <script src="{{ '/js/scripts.js' | url }}"></script>
  </body>
</html>