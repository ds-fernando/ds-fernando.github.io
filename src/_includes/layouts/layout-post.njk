<!DOCTYPE html>
<html lang="es">
  <head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{{ title }}</title>
    <meta name="description" content="{{ description }}">
    <link href="https://cdn.jsdelivr.net/npm/bulma@0.9.4/css/bulma.min.css" rel="stylesheet">
    <link rel="stylesheet" href="{{ '/css/styles.css' | url }}">

    <!-- Google tag (gtag.js) -->
    <script async src="https://www.googletagmanager.com/gtag/js?id=G-C4J1GFZMPF"></script>
    <script>
      window.dataLayer = window.dataLayer || [];
      function gtag() {
        dataLayer.push(arguments);
      }
      gtag('js', new Date());
      gtag('config', 'G-C4J1GFZMPF');
    </script>
  </head>

  <body>
    <div class="container">
      {% include "header.njk" %}

      <div class="layout">
        <div class="columns">
          <div class="column is-one-quarter">
            {% include "nav_posts.njk" %}
          </div>

          <div class="column">
            <main class="content is-medium" style="max-width: 680px; margin: 0 auto;">
              <h1 class="title is-3">{{ title }}</h1>
              <p class="has-text-grey">{{ date | date }}</p>

              <hr>

              {{ content | safe }}
            </main>
          </div>
        </div>
      </div>

      {% include "footer.njk" %}
    </div>

    <script src="{{ '/js/scripts.js' | url }}"></script>
  </body>
</html>