---
layout: layouts/layout-articles.njk
title: Artículos 
---
<h1 class="is-size-2">{{title}}</h1>
<p style="margin: -0.75rem 0 1.5rem; display:flex; align-items:center; gap:6px;">
  <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" style="color:#999; opacity:0.7;"><circle cx="12" cy="12" r="3"/><circle cx="4" cy="6" r="2"/><circle cx="20" cy="6" r="2"/><circle cx="4" cy="18" r="2"/><circle cx="20" cy="18" r="2"/><line x1="6" y1="6" x2="10" y2="11"/><line x1="18" y1="6" x2="14" y2="11"/><line x1="6" y1="18" x2="10" y2="13"/><line x1="18" y1="18" x2="14" y2="13"/></svg>
  <a href="/blog/grafo/" style="font-size:13px; color:#999; text-decoration:none; border-bottom: 0.5px solid #ccc;">Ver mapa de conexiones</a>
</p>
<ul class="article-list">
  {% for post in collections.allPosts %}
    <li style="--i: {{ loop.index }}">
      <a href="{{ post.url | url }}">{{ post.data.title }}</a>
    </li>
  {% else %}
    <li>No hay artículos recientes disponibles.</li>
  {% endfor %}
</ul>